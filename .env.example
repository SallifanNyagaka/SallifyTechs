# Environment Variables Template
# 
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to Git - it's in .gitignore
# 
# For production, add these variables to Vercel Dashboard:
# https://vercel.com/dashboard → Select Project → Settings → Environment Variables

# ==============================================================================
# CLIENT-SIDE VARIABLES (NEXT_PUBLIC_)
# These are exposed to the browser - DO NOT include secrets here
# ==============================================================================

# Firebase Configuration (Get from Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Site Verification (for SEO)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Admin Emails (comma-separated)
NEXT_PUBLIC_ADMIN_EMAILS=

# Exchange Rate (USD to KES, fallback if API unavailable)
NEXT_PUBLIC_USD_TO_KES_RATE=155

# ==============================================================================
# SERVER-SIDE VARIABLES (PRIVATE - SENSITIVE CREDENTIALS)
# These are only available on the server - NEVER expose in client code
# ==============================================================================

# Email Configuration (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
OWNER_NOTIFICATION_EMAIL=

# Twilio Configuration (for SMS/WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# WhatsApp Cloud API Configuration
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en_US
WHATSAPP_ADMIN_NUMBER=

# WhatsApp Webhook Configuration
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Enable WhatsApp Delivery Feature
ENABLE_WHATSAPP_DELIVERY=false

# Site URL (Server-side fallback)
SITE_URL=http://localhost:3000

# OpenAI Configuration (for Chat Feature)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Invoice Configuration
INVOICE_TAX_ENABLED=true
INVOICE_TAX_RATE=0.16

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
#
# 1. Copy this file to .env.local
#    cp .env.example .env.local
#
# 2. Fill in ALL values with your credentials
#    See documentation files for where to get each value
#
# 3. Run development server
#    npm run dev
#
# 4. For production on Vercel:
#    - Add each variable to Vercel Dashboard
#    - Use production credentials
#    - Each value should be filled in (no empty values)
#
# 5. For more details:
#    - See README_ENV_VARIABLES.md (Quick intro)
#    - See ENV_QUICK_REFERENCE.md (Quick lookup)
#    - See VERCEL_ENV_SETUP.md (Deployment guide)
#    - See ENV_AUDIT.md (Complete technical details)
# ==============================================================================
